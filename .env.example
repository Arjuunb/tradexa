# ─────────────────────────────────────────────────────────────
#  Tradexa — Environment Variables Template
#  Copy this file to `.env` (local) or set in your host's
#  dashboard (Vercel / Netlify / etc). NEVER commit a real .env.
# ─────────────────────────────────────────────────────────────

# ─── Gemini AI (required for Trade Bot, AI Coach, Daily Digest, Weekly Review) ───
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Supabase auth (required for login/signup/protected app pages) ───
# Get from: https://app.supabase.com → your project → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Get from: Supabase → Settings → API → JWT Settings → "JWT Secret"
# Used server-side ONLY to verify access tokens. Never exposed to the browser.
SUPABASE_JWT_SECRET=

# ─── Supabase service role key (required for admin-users API) ───
# Get from: Supabase → Settings → API → "service_role" key
# NEVER expose this to the browser — server-side use only.
# Grants full database access, bypassing RLS.
SUPABASE_SERVICE_KEY=
